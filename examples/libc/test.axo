func main(): Integer {
    var i = 0

    while(
        i < 10,
        {
            libc.println_i64(i)

            libc.print_str("Fac: ")
            libc.println_i64(libc.factorial(i))

            i = i + 1
        }
    )

    const point = Point { x = 3, y = 5 }

    libc.println_str("Old:")
    libc.println_i64(point.x)

    point.x = 6

    libc.println_str("New:")

    libc.println_i64(point.x)

    libc.test_logic(2)

    libc.test_array()

    libc.test_user_input()

    return(libc.EXIT_SUCCESS)
}