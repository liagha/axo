struct Point {
    const x: Integer,
    const y: Integer,

    func print_position(const point: Point) {
        libc.println_i64(point.x)
        libc.println_i64(point.y)
    }
}

union FloatOrInt {
    const int: Integer,
    const float: Float,
}

enum Color {
    const Red,
    const Yellow,

    struct GrayScale {
        const value: Integer
    }

    enum Blue {
        const Cyan,
        const LightBlue,
        const DarkBlue
    }
}

