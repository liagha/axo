struct Point {
    const x: Integer,
    const y: Integer,

    func print_position(const point: Point) {
        libc.println_i64(point.x)
        libc.println_i64(point.y)
    }
}

union FloatOrInt {
    const int: Integer,
    const float: Float,
}

enum Color {
    const Red,
    const Blue,
    const Yellow,
}

func main() {
    libc.test_malloc()

    const point = Point {
        x = 333,
        y = 454
    }

    const idk = FloatOrInt {
        int = 3
    }

    const color = Color.Red

    if(
        color == Color.Red,
        libc.println_str("Red"),
        libc.println_str("Not Red")
    )

    libc.println_i64(idk.int);

    Point.print_position(point)
}
