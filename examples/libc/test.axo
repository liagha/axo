struct Point {
    const x: Integer,
    const y: Integer,

    func print_position(const point: Point) {
        libc.println_i64(point.x)
        libc.println_i64(point.y)
    }
}

union FloatOrInt {
    const int: Integer,
    const float: Float,
}

enum Color {
    const Red,
    const Yellow,

    struct GrayScale {
        const value: Integer
    }

    enum Blue {
        Cyan,
        LightBlue,
        DarkBlue
    }
}

func main() {
    libc.test_malloc()

    const point = Point {
        x = 333,
        y = 454
    }

    const idk = FloatOrInt {
        int = 3
    }

    const red = Color.Yellow

    const cyan = Color.Blue.Cyan

    const black = Color.GrayScale {
        value = 100
    }

    const Color.GrayScale { value } = black;

    value
}
