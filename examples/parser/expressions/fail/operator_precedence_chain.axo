const a = 10
const b = 3
const c = 2

const add = a + b
const sub = a - b
const mul = a * b
const div = a / b
const rem = a % b

const shl = a << c
const shr = a >> c

const band = a & b
const bor = a | b
const bxor = a ^ b

const eq = a == b
const ne = a != b
const lt = a < b
const le = a <= b
const gt = a > b
const ge = a >= b

const mix = a + b * c
const logicand = lt && gt
const logicor = lt || gt
